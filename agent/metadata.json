{
  "type": "https://eips.ethereum.org/EIPS/eip-8004#registration-v1",
  "name": "Payflow Agent",
  "description": "An onchain invoicing, escrow, and agent-to-agent job coordination system using Celo stablecoins.",
  "image": "https://payflow-agent.vercel.app/payflow-icon.png",
  "services": [
    {
      "name": "web",
      "endpoint": "https://payflow-agent.vercel.app"
    },
    {
      "name": "A2A",
      "endpoint": "https://payflow-agent.vercel.app/.well-known/agent.json",
      "version": "1.0"
    },
    {
      "name": "jobs",
      "endpoint": "https://payflow-agent.vercel.app/api/jobs",
      "version": "1.0"
    },
    {
      "name": "autonomous-worker",
      "endpoint": "https://payflow-agent.vercel.app/api/agent/worker",
      "version": "1.0"
    }
  ],
  "registrations": [
    {
      "agentRegistry": "eip155:42220:0x8004A169FB4a3325136EB29fA0ceB6D2e539a432"
    }
  ],
  "supportedTrust": ["reputation", "validation"]
}
